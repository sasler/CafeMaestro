<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CafeMaestro.ViewModels"
             x:Class="CafeMaestro.SettingsPage"
             x:Name="RootPage"
             x:DataType="vm:SettingsPageViewModel"
             BackgroundColor="{DynamicResource PageBackgroundColor}"
             Title="Settings">
       <ContentPage.Resources>
              <!-- Popup resources for roast level editing -->
              <Style x:Key="EditEntryStyle"
                     TargetType="Entry">
                     <Setter Property="BackgroundColor"
                             Value="{DynamicResource EntryBackgroundColor}"/>
                     <Setter Property="TextColor"
                             Value="{DynamicResource PrimaryTextColor}"/>
                     <Setter Property="PlaceholderColor"
                             Value="{DynamicResource SecondaryTextColor}"/>
                     <Setter Property="HeightRequest"
                             Value="50"/>
                     <Setter Property="FontSize"
                             Value="16"/>
              </Style>
       </ContentPage.Resources>

       <Grid>
              <!-- Main ScrollView content -->
              <ScrollView Padding="0"
                          Margin="0">
                     <Grid RowDefinitions="Auto, *"
                           Padding="0"
                           Margin="0">
                            <!-- Header Area - Clean Design -->
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="Auto,*"
                                  Padding="20,20"
                                  HeightRequest="100"
                                  HorizontalOptions="Fill"
                                  Margin="0">
                                   <!-- Logo and Title within Header -->
                                   <Image Grid.Column="0"
                                          Source="settings_icon.png"
                                          HeightRequest="60"
                                          WidthRequest="60"
                                          Aspect="AspectFit"
                                          VerticalOptions="Center"/>
                                   <Label Grid.Column="1"
                                          Text="Application Settings"
                                          FontSize="28"
                                          FontAttributes="Bold"
                                          HorizontalOptions="Start"
                                          VerticalOptions="Center"
                                          TextColor="{DynamicResource PrimaryColor}"
                                          Margin="16,0,0,0"/>
                            </Grid>

                            <!-- Main Content Area -->
                            <VerticalStackLayout Grid.Row="1"
                                                 Padding="24,0,24,24"
                                                 Spacing="15"
                                                 BackgroundColor="{DynamicResource PageBackgroundColor}"
                                                 Margin="0,10,0,0">

                                   <!-- Data File Section -->
                                   <Border x:Name="DataFileSection"
                                           Stroke="{DynamicResource BorderColor}"
                                           BackgroundColor="{DynamicResource PageBackgroundColor}"
                                           StrokeThickness="0.5"
                                           StrokeShape="RoundRectangle 12">
                                          <Border.Shadow>
                                                 <Shadow Brush="{DynamicResource BorderColor}"
                                                         Offset="0,2"
                                                         Radius="4"
                                                         Opacity="0.2"/>
                                          </Border.Shadow>
                                          <VerticalStackLayout Spacing="16"
                                                               Padding="16,10">
                                                 <Label Text="Data File"
                                                        FontSize="18"
                                                        FontAttributes="Bold"
                                                        TextColor="{DynamicResource PrimaryTextColor}"/>

                                                 <Label Text="{Binding DataFilePath}"
                                                         FontSize="14"
                                                         LineBreakMode="CharacterWrap"
                                                         TextColor="{DynamicResource PrimaryTextColor}"/>

                                                 <HorizontalStackLayout Spacing="10"
                                                                        HorizontalOptions="Center">
                                                         <ImageButton Source="new_icon.png"
                                                                     Command="{Binding CreateNewDataFileCommand}"
                                                                     BackgroundColor="{DynamicResource PrimaryColor}"
                                                                     WidthRequest="50"
                                                                     HeightRequest="50"
                                                                     Padding="5"
                                                                     CornerRadius="25"/>

                                                         <ImageButton Source="load_icon.png"
                                                                     Command="{Binding ChooseExistingDataFileCommand}"
                                                                     BackgroundColor="{DynamicResource SuccessColor}"
                                                                     WidthRequest="50"
                                                                     HeightRequest="50"
                                                                     Padding="5"
                                                                     CornerRadius="25"/>

                                                         <ImageButton Source="export_icon.png"
                                                                     Command="{Binding ExportCommand}"
                                                                     BackgroundColor="{DynamicResource SecondaryColor}"
                                                                     WidthRequest="50"
                                                                     HeightRequest="50"
                                                                     Padding="5"
                                                                     CornerRadius="25"/>

                                                         <ImageButton Source="import_icon.png"
                                                                     Command="{Binding ImportCommand}"
                                                                     BackgroundColor="{DynamicResource TertiaryColor}"
                                                                     WidthRequest="50"
                                                                     HeightRequest="50"
                                                                     Padding="5"
                                                                     CornerRadius="25"/>
                                                 </HorizontalStackLayout>

                                                 <HorizontalStackLayout Spacing="10"
                                                                        HorizontalOptions="Center">
                                                         <Button Text="Share Data File"
                                                                 Command="{Binding ShareDataFileCommand}"
                                                                 BackgroundColor="{DynamicResource SecondaryColor}"
                                                                 TextColor="{DynamicResource ButtonTextColor}"
                                                                 HeightRequest="48"
                                                                 CornerRadius="24"
                                                                 HorizontalOptions="FillAndExpand"/>

                                                         <Button Text="Share Roast Log"
                                                                 Command="{Binding ShareRoastLogCsvCommand}"
                                                                 BackgroundColor="{DynamicResource SecondaryColor}"
                                                                 TextColor="{DynamicResource ButtonTextColor}"
                                                                 HeightRequest="48"
                                                                 CornerRadius="24"
                                                                 HorizontalOptions="FillAndExpand"/>
                                                 </HorizontalStackLayout>

                                                 <Button Text="Use Default Location"
                                                         Command="{Binding UseDefaultDataFileCommand}"
                                                         BackgroundColor="{DynamicResource AccentColor}"
                                                         TextColor="{DynamicResource ButtonTextColor}"
                                                         HeightRequest="48"
                                                         CornerRadius="24"
                                                         HorizontalOptions="Fill"/>
                                         </VerticalStackLayout>
                                  </Border>

                                   <!-- Roast Levels Section -->
                                   <Border Stroke="{DynamicResource BorderColor}"
                                           BackgroundColor="{DynamicResource PageBackgroundColor}"
                                           StrokeThickness="0.5"
                                           StrokeShape="RoundRectangle 12">
                                          <Border.Shadow>
                                                 <Shadow Brush="{DynamicResource BorderColor}"
                                                         Offset="0,2"
                                                         Radius="4"
                                                         Opacity="0.2"/>
                                          </Border.Shadow>
                                          <VerticalStackLayout Spacing="5"
                                                               Padding="16,10">
                                                 <Label Text="Roast Levels"
                                                        FontSize="18"
                                                        FontAttributes="Bold"
                                                        TextColor="{DynamicResource PrimaryTextColor}"/>

                                                 <Label Text="Configure custom roast levels based on weight loss percentage"
                                                        FontSize="14"
                                                        TextColor="{DynamicResource SecondaryTextColor}"/>

                                                 <!-- List of roast levels -->
                                                 <CollectionView ItemsSource="{Binding RoastLevels}"
                                                                 EmptyView="No roast levels defined"
                                                                 SelectionMode="None">
                                                         <CollectionView.ItemTemplate>
                                                               <DataTemplate x:DataType="vm:RoastLevelViewModel">
                                                                      <Grid Padding="5"
                                                                            ColumnDefinitions="*, Auto, Auto">
                                                                            <Border Grid.Column="0"
                                                                                    BackgroundColor="{DynamicResource NeutralColor}"
                                                                                    StrokeShape="RoundRectangle 8"
                                                                                    Padding="3">
                                                                                   <VerticalStackLayout>
                                                                                           <Label Text="{Binding Name}"
                                                                                                  FontSize="16"
                                                                                                  FontAttributes="Bold"
                                                                                                  TextColor="{DynamicResource PrimaryTextColor}"/>
                                                                                           <Label Text="{Binding DisplayRange}"
                                                                                                  FontSize="14"
                                                                                                  TextColor="{DynamicResource SecondaryTextColor}"/>
                                                                                    </VerticalStackLayout>
                                                                             </Border>

                                                                            <ImageButton Grid.Column="1"
                                                                                         Source="edit_icon.png"
                                                                                          Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.EditRoastLevelCommand}"
                                                                                         CommandParameter="{Binding .}"
                                                                                          BackgroundColor="{DynamicResource SwipeEditColor}"
                                                                                         WidthRequest="40"
                                                                                         HeightRequest="40"
                                                                                         Padding="8"
                                                                                          Margin="8,0,0,0"
                                                                                          CornerRadius="20"/>

                                                                            <ImageButton Grid.Column="2"
                                                                                         Source="delete_icon.png"
                                                                                          Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.DeleteRoastLevelCommand}"
                                                                                         CommandParameter="{Binding .}"
                                                                                          BackgroundColor="{DynamicResource SwipeDeleteColor}"
                                                                                         WidthRequest="40"
                                                                                         HeightRequest="40"
                                                                                         Padding="8"
                                                                                          Margin="8,0,0,0"
                                                                                          CornerRadius="20"/>
                                                                      </Grid>
                                                               </DataTemplate>
                                                        </CollectionView.ItemTemplate>
                                                 </CollectionView>

                                                 <Grid ColumnDefinitions="*,*"
                                                       ColumnSpacing="12">
                                                        <Button Grid.Column="0"
                                                                Text="Add New Roast Level"
                                                                Command="{Binding AddRoastLevelCommand}"
                                                                BackgroundColor="{DynamicResource SecondaryColor}"
                                                                TextColor="{DynamicResource ButtonTextColor}"
                                                                HeightRequest="50"
                                                                CornerRadius="25"
                                                                HorizontalOptions="Fill"/>
                                                        <Button Grid.Column="1"
                                                                Text="Reset Defaults"
                                                                Command="{Binding ResetRoastLevelsToDefaultsCommand}"
                                                                BackgroundColor="{DynamicResource AccentColor}"
                                                                TextColor="{DynamicResource ButtonTextColor}"
                                                                HeightRequest="50"
                                                                CornerRadius="25"
                                                                HorizontalOptions="Fill"/>
                                                 </Grid>
                                         </VerticalStackLayout>
                                  </Border>

                                   <!-- Theme Section -->
                                   <Border Stroke="{DynamicResource BorderColor}"
                                           StrokeThickness="0.5"
                                           StrokeShape="RoundRectangle 12">
                                          <Border.Shadow>
                                                 <Shadow Brush="{DynamicResource BorderColor}"
                                                         Offset="0,2"
                                                         Radius="4"
                                                         Opacity="0.2"/>
                                          </Border.Shadow>
                                          <VerticalStackLayout Spacing="16"
                                                               Padding="16,10">
                                                 <Label Text="App Theme"
                                                        FontSize="18"
                                                        FontAttributes="Bold"
                                                        TextColor="{DynamicResource PrimaryTextColor}"/>

                                                 <Picker Title="Select your preferred theme for the app"
                                                         SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}"
                                                         TextColor="{DynamicResource PrimaryTextColor}"
                                                         TitleColor="{DynamicResource SecondaryTextColor}"
                                                         BackgroundColor="{DynamicResource PickerBackgroundColor}"
                                                         Margin="0,5,0,10">
                                                        <Picker.Items>
                                                               <x:String>System Theme</x:String>
                                                               <x:String>Light Theme</x:String>
                                                               <x:String>Dark Theme</x:String>
                                                        </Picker.Items>
                                                 </Picker>
                                          </VerticalStackLayout>
                                   </Border>

                                   <!-- About Section -->
                                   <Border Stroke="{DynamicResource BorderColor}"
                                           BackgroundColor="{DynamicResource PageBackgroundColor}"
                                           StrokeThickness="0.5"
                                           StrokeShape="RoundRectangle 12">
                                          <Border.Shadow>
                                                 <Shadow Brush="{DynamicResource BorderColor}"
                                                         Offset="0,2"
                                                         Radius="4"
                                                         Opacity="0.2"/>
                                          </Border.Shadow>
                                          <VerticalStackLayout Spacing="8"
                                                               Padding="16,10">

                                                 <Label Text="About"
                                                        FontSize="18"
                                                        FontAttributes="Bold"
                                                        TextColor="{DynamicResource PrimaryTextColor}"/>

                                                 <Label Text="CafeMaestro - Coffee Roasting App"
                                                        FontSize="16"
                                                        TextColor="{DynamicResource PrimaryTextColor}"/>

                                                 <HorizontalStackLayout Spacing="5">
                                                        <Label Text="Version:"
                                                               FontSize="14"
                                                               TextColor="{DynamicResource PrimaryTextColor}"/>
                                                        <Label Text="{Binding VersionDisplay}"
                                                               FontSize="14"
                                                               TextColor="{DynamicResource PrimaryTextColor}"/>
                                                 </HorizontalStackLayout>

                                                  <!-- Version History Label -->
                                                 <Label Text="{Binding VersionHistoryDisplay}"
                                                        FontSize="14"
                                                        TextColor="{DynamicResource SecondaryTextColor}"
                                                        LineBreakMode="WordWrap"/>

                                                  <Label Text="© 2025 CafeMaestro Team"
                                                         FontSize="14"
                                                         TextColor="{DynamicResource SecondaryTextColor}"/>
                                         </VerticalStackLayout>
                                  </Border>
                           </VerticalStackLayout>
                     </Grid>
              </ScrollView>

              <!-- Popup for editing roast levels -->
              <Grid x:Name="EditRoastLevelPopup"
                    IsVisible="{Binding IsEditRoastLevelPopupVisible}"
                    BackgroundColor="{DynamicResource ModalOverlayColor}"
                    InputTransparent="False">
                     <Border BackgroundColor="{DynamicResource PageBackgroundColor}"
                             WidthRequest="320"
                             StrokeShape="RoundRectangle 12"
                             Stroke="{DynamicResource BorderColor}"
                             StrokeThickness="1"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">
                            <Grid RowDefinitions="Auto,*,Auto"
                                  Padding="20">
                                   <!-- Header -->
                                   <Label Text="{Binding EditPopupTitle}"
                                          Grid.Row="0"
                                          FontSize="22"
                                          FontAttributes="Bold"
                                          HorizontalOptions="Center"
                                          TextColor="{DynamicResource PrimaryTextColor}"
                                          Margin="0,0,0,15"/>

                                   <!-- Form fields -->
                                   <VerticalStackLayout Grid.Row="1"
                                                        Spacing="15">
                                          <Label Text="Name"
                                                 FontSize="16"
                                                 TextColor="{DynamicResource PrimaryTextColor}"/>
                                          <Entry Text="{Binding RoastLevelName}"
                                                 Placeholder="Enter roast level name"
                                                 Style="{StaticResource EditEntryStyle}"/>

                                          <Label Text="Min Weight Loss (%)"
                                                 FontSize="16"
                                                 TextColor="{DynamicResource PrimaryTextColor}"/>
                                          <Entry Text="{Binding MinWeightLossText}"
                                                 Placeholder="0.0"
                                                 Keyboard="Numeric"
                                                 Style="{StaticResource EditEntryStyle}"/>

                                          <Label Text="Max Weight Loss (%)"
                                                 FontSize="16"
                                                 TextColor="{DynamicResource PrimaryTextColor}"/>
                                          <Entry Text="{Binding MaxWeightLossText}"
                                                 Placeholder="100.0"
                                                 Keyboard="Numeric"
                                                 Style="{StaticResource EditEntryStyle}"/>
                                   </VerticalStackLayout>

                                   <!-- Action buttons -->
                                   <HorizontalStackLayout Grid.Row="2"
                                                          Spacing="10"
                                                          HorizontalOptions="Center"
                                                          Margin="0,15,0,0">
                                          <Button Text="Save"
                                                  Command="{Binding SaveRoastLevelCommand}"
                                                  Style="{StaticResource ActionButtonStyle}"
                                                  TextColor="{DynamicResource ButtonTextColor}"
                                                  WidthRequest="120"
                                                  HeightRequest="45"
                                                  CornerRadius="22"/>

                                          <Button Text="Cancel"
                                                  Command="{Binding CancelRoastLevelCommand}"
                                                  Style="{StaticResource ButtonStyle}"
                                                  BackgroundColor="{DynamicResource NeutralColor}"
                                                  TextColor="{DynamicResource PrimaryTextColor}"
                                                  WidthRequest="120"
                                                  HeightRequest="45"
                                                  CornerRadius="22"/>
                                   </HorizontalStackLayout>
                            </Grid>
                     </Border>
              </Grid>
       </Grid>
</ContentPage>
