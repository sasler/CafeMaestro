<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CafeMaestro.ViewModels"
             x:Class="CafeMaestro.RoastPage"
             BackgroundColor="{DynamicResource PageBackgroundColor}"
             Title="{Binding PageTitle}">
    <ScrollView Padding="0"
                Margin="0">
        <Grid RowDefinitions="Auto, *"
              Padding="0"
              Margin="0">
            <Grid Grid.Row="0"
                  ColumnDefinitions="Auto,*,Auto"
                  Padding="20,20"
                  HeightRequest="100"
                  HorizontalOptions="Fill"
                  Margin="0">
                <Image Grid.Column="0"
                       Source="roast_icon.png"
                       HeightRequest="60"
                       WidthRequest="60"
                       Aspect="AspectFit"
                       VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="{Binding PageTitle}"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Start"
                       VerticalOptions="Center"
                       TextColor="{DynamicResource PrimaryColor}"
                       Margin="16,0,0,0"/>
                <HorizontalStackLayout Grid.Column="2"
                                       Spacing="10"
                                       VerticalOptions="Center">
                    <ImageButton x:Name="CancelButton"
                                 Source="cancel_icon.png"
                                 Command="{Binding CancelCommand}"
                                 BackgroundColor="{DynamicResource SwipeDeleteColor}"
                                 WidthRequest="50"
                                 HeightRequest="50"
                                 Padding="5"
                                 CornerRadius="25" />
                    <ImageButton x:Name="SaveRoastButton"
                                 Source="save_icon.png"
                                 Command="{Binding SaveCommand}"
                                 BackgroundColor="{DynamicResource PrimaryColor}"
                                 WidthRequest="50"
                                 HeightRequest="50"
                                 Padding="5"
                                 CornerRadius="25" />
                </HorizontalStackLayout>
            </Grid>

            <VerticalStackLayout Grid.Row="1"
                                 Padding="24,0,24,24"
                                 Spacing="15"
                                 BackgroundColor="{DynamicResource PageBackgroundColor}"
                                 Margin="0,10,0,0">

                <VerticalStackLayout Spacing="15">
                    <Border Stroke="{DynamicResource BorderColor}"
                            BackgroundColor="{DynamicResource NeutralColor}"
                            StrokeShape="RoundRectangle 12"
                            HorizontalOptions="Fill"
                            HeightRequest="110">
                        <Border.Shadow>
                            <Shadow Brush="#20000000"
                                    Offset="0,3"
                                    Radius="6"
                                    Opacity="0.2"/>
                        </Border.Shadow>
                        <Grid>
                            <Label x:Name="TimeDisplayLabel"
                                   Text="{Binding TimerDisplay}"
                                   FontSize="80"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   TextColor="{DynamicResource PrimaryColor}"/>

                            <Border x:Name="TimerRunningIndicator"
                                    WidthRequest="20"
                                    HeightRequest="20"
                                    BackgroundColor="Red"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    HorizontalOptions="End"
                                    VerticalOptions="Start"
                                    Margin="0,10,10,0"
                                    Padding="0"
                                    IsVisible="False"/>

                            <Entry x:Name="TimeEntry"
                                   Text="00:00"
                                   FontSize="1"
                                   Opacity="0"
                                   Keyboard="Numeric"
                                   MaxLength="5"
                                   IsEnabled="{Binding IsTimeEntryEnabled}"
                                   Focused="TimeEntry_Focused"
                                   Unfocused="TimeEntry_Unfocused"
                                   TextChanged="TimeEntry_TextChanged"/>
                        </Grid>
                    </Border>
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="10">
                        <ImageButton x:Name="StartTimerButton"
                                     Source="timer_play_icon.png"
                                     Command="{Binding StartTimerCommand}"
                                     IsEnabled="{Binding CanStartTimer}"
                                     BackgroundColor="{DynamicResource PrimaryColor}"
                                     WidthRequest="50"
                                     HeightRequest="50"
                                     Padding="5"
                                     CornerRadius="25" />
                        <ImageButton x:Name="PauseTimerButton"
                                     Source="timer_pause_icon.png"
                                     Command="{Binding PauseTimerCommand}"
                                     IsEnabled="{Binding CanPauseTimer}"
                                     BackgroundColor="{DynamicResource TertiaryColor}"
                                     WidthRequest="50"
                                     HeightRequest="50"
                                     Padding="5"
                                     CornerRadius="25" />
                        <ImageButton x:Name="StopTimerButton"
                                     Source="timer_stop_icon.png"
                                     Command="{Binding StopTimerCommand}"
                                     IsEnabled="{Binding CanStopTimer}"
                                     BackgroundColor="{DynamicResource TertiaryColor}"
                                     WidthRequest="50"
                                     HeightRequest="50"
                                     Padding="5"
                                     CornerRadius="25" />
                        <ImageButton x:Name="ResetTimerButton"
                                     Source="timer_reset_icon.png"
                                     Command="{Binding ResetTimerCommand}"
                                     BackgroundColor="{DynamicResource TertiaryColor}"
                                     WidthRequest="50"
                                     HeightRequest="50"
                                     Padding="5"
                                     CornerRadius="25" />
                        <ImageButton x:Name="FirstCrackButton"
                                     Source="first_crack_icon.png"
                                     Command="{Binding MarkFirstCrackCommand}"
                                     IsEnabled="{Binding CanMarkFirstCrack}"
                                     BackgroundColor="{DynamicResource AccentColor}"
                                     WidthRequest="50"
                                     HeightRequest="50"
                                     Padding="5"
                                     CornerRadius="25" />
                    </HorizontalStackLayout>

                    <Label x:Name="FirstCrackLabel"
                           Text="{Binding FirstCrackLabel}"
                           FontSize="16"
                           HorizontalOptions="Center"
                           TextColor="{DynamicResource AccentColor}"
                           Margin="0,10,0,0"/>
                </VerticalStackLayout>

                <Picker x:Name="BeanPicker"
                        Title="{Binding BeanPickerTitle}"
                        ItemsSource="{Binding AvailableBeans}"
                        SelectedItem="{Binding SelectedBean, Mode=TwoWay}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        TextColor="{DynamicResource PrimaryTextColor}"
                        BackgroundColor="{DynamicResource PickerBackgroundColor}" />

                <Border x:Name="PreviousRoastInfoSection"
                        IsVisible="{Binding HasPreviousRoast}"
                        Margin="0,5,0,10"
                        Padding="10"
                        BackgroundColor="{AppThemeBinding Light=#f0f0f0, Dark=#303030}"
                        Stroke="{AppThemeBinding Light=#dddddd, Dark=#444444}"
                        StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout>
                        <Label Text="Previous Roast"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryColor}"
                               Margin="0,0,0,5"/>
                        <Label x:Name="PreviousRoastSummaryLabel"
                               Text="{Binding PreviousRoastSummary}"
                               FontSize="14"
                               LineBreakMode="WordWrap"/>
                        <Label x:Name="PreviousRoastDetailsLabel"
                               Text="{Binding PreviousRoastDetails}"
                               FontSize="14"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Roasting Temperature (°C):"
                       TextColor="{DynamicResource PrimaryTextColor}"/>
                <Border Stroke="{DynamicResource EntryBorderColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 5">
                    <Entry x:Name="TemperatureEntry"
                           Text="{Binding TemperatureText, Mode=TwoWay}"
                           Keyboard="Numeric"
                           Placeholder="Enter temperature"
                           TextColor="{DynamicResource PrimaryTextColor}"
                           BackgroundColor="{DynamicResource EntryBackgroundColor}"
                           PlaceholderColor="{DynamicResource PlaceholderColor}"/>
                </Border>

                <Label Text="Batch Weight (g):"
                       TextColor="{DynamicResource PrimaryTextColor}"/>
                <Border Stroke="{DynamicResource EntryBorderColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 5">
                    <Entry x:Name="BatchWeightEntry"
                           Text="{Binding BatchWeightText, Mode=TwoWay}"
                           Keyboard="Numeric"
                           Placeholder="Enter batch weight"
                           TextColor="{DynamicResource PrimaryTextColor}"
                           BackgroundColor="{DynamicResource EntryBackgroundColor}"
                           PlaceholderColor="{DynamicResource PlaceholderColor}"/>
                </Border>

                <Label x:Name="BatchWeightWarningLabel"
                       IsVisible="{Binding IsBatchWeightWarningVisible}"
                       Text="{Binding BatchWeightWarningText}"
                       TextColor="{StaticResource SwipeDeleteColor}"
                       FontAttributes="Bold"/>

                <Label Text="Final Weight (g):"
                       TextColor="{DynamicResource PrimaryTextColor}"/>
                <Border Stroke="{DynamicResource EntryBorderColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 5">
                    <Entry x:Name="FinalWeightEntry"
                           Text="{Binding FinalWeightText, Mode=TwoWay}"
                           Keyboard="Numeric"
                           Placeholder="Enter final weight"
                           TextColor="{DynamicResource PrimaryTextColor}"
                           BackgroundColor="{DynamicResource EntryBackgroundColor}"
                           PlaceholderColor="{DynamicResource PlaceholderColor}"/>
                </Border>

                <Label x:Name="LossPercentLabel"
                       Text="{Binding LossPercentLabel}"
                       FontSize="18"
                       TextColor="{DynamicResource PrimaryColor}"/>

                <Editor x:Name="NotesEditor"
                        Text="{Binding Notes, Mode=TwoWay}"
                        Placeholder="Add notes about this roast..."
                        HeightRequest="100"
                        AutoSize="TextChanges"
                        TextColor="{DynamicResource PrimaryTextColor}"
                        BackgroundColor="{DynamicResource EntryBackgroundColor}"/>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
